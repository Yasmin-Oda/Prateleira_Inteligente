<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora</title>
</head>
<body>

    Faturamento mensal atual (R$): <input type="text" id="input_faturamento"><br><br>
    <button onclick="CalcularPerda()">Calcular potencial</button><br><br>

    <div id="div_mensagem"></div>
    
</body>
</html>

<script>
    function CalcularPerda() {

        let faturamento = Number(input_faturamento.value);
        let taxaAbandono = 0.7019; // Taxa de abandono (70,19%)
        let taxaConversao = 1 - taxaAbandono; // Conversão real (100% - 70,19%)
        let potencialTotal = faturamento / taxaConversao;  // Potencial total de vendas
        let valorPerdido = potencialTotal - faturamento; // Perdido

        div_mensagem.innerHTML = `Potencial total estimado de vendas: R$${potencialTotal.toFixed(2)} <br><br> 
            Valor estimado perdido: R$ ${valorPerdido.toFixed(2)} <br><br>
            "Segundo dados recentes do Baymard Institute, que analisou mais de 48 estudos, 
            a taxa média global de abandono de carrinho em 2025 é de 70,19%. <br>
            Isso significa que apenas 29,81% do potencial de compra é convertido em venda".<br><br><b>
            Com a Smart Insight, sua empresa pode usar dados reais de comportamento
            para reduzir perdas e transformar interesse em faturamento.</b>`
        ;

    }
</script>
